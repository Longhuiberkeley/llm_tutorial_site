---
import '../styles/global.css';
import SidebarTOC from '../components/SidebarTOC.astro';

interface Props {
	title: string;
	description?: string;
	chapter?: string;
	hideHeader?: boolean;
	activeId?: string;
}

const { title, description, chapter, hideHeader = false, activeId } = Astro.props;

// Normalize BASE_URL to always have a trailing slash (Astro v6 omits it)
const BASE = (import.meta.env.BASE_URL + '/').replace(/\/+$/, '/'); // '/llm_tutorial_site/'
// Determine current language from URL, stripping the base path first
const rawPath = Astro.url.pathname;
const basePrefix = BASE.slice(0, -1); // '/llm_tutorial_site'
const path = rawPath.startsWith(basePrefix) ? rawPath.slice(basePrefix.length) || '/' : rawPath;
const isZh = path.startsWith('/zh-hant-hk');
const currentLang = isZh ? 'zh-hant-hk' : 'en';
const langPrefix = BASE + currentLang;

// Localized Strings
const t = {
	en: {
		overview: "Overview",
		who: "Who is this for?",
		about: "About & Contact",
		curriculum: "Curriculum",
		mastery: "LLM Mastery Series",
		menu: "Menu"
	},
	zh: {
		overview: "概覽",
		who: "這門課程適合誰？",
		about: "關於與聯繫",
		curriculum: "課程大綱",
		mastery: "LLM 精通系列",
		menu: "選單"
	}
};

const i18n = isZh ? t.zh : t.en;
---

<!doctype html>
<html lang={currentLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description || "Interactive LLM Tutorial"} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="base-url" content={BASE} />
		<link rel="icon" type="image/svg+xml" href={BASE + 'favicon.svg'} />
		<title>{title} - AI Unpacked</title>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
		<link rel="stylesheet" href={BASE + 'css/animations.css'}/>

		<!-- "No Flicker" Dark Mode Script -->
		<script is:inline>
			const getThemePreference = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			};
			const isDark = getThemePreference() === 'dark';
			document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
		</script>
	</head>
	<body class="bg-background text-on-surface font-body selection:bg-primary-fixed selection:text-on-primary-fixed">
		<!-- TopNavBar -->
		<nav class="fixed top-0 w-full z-50 bg-background/80 backdrop-blur-md shadow-[0_20px_40px_rgba(146,74,49,0.06)] flex justify-between items-center px-4 md:px-8 py-4 max-w-full">
			<div class="flex items-center gap-3">
				<!-- Hamburger Menu for Mobile -->
				<button id="menu-toggle" class="lg:hidden p-2 rounded-md hover:bg-surface-container transition-colors" aria-label="Toggle menu">
					<span class="material-symbols-outlined text-on-surface">menu</span>
				</button>
				<a href={langPrefix + "/"} class="flex items-center gap-2 text-xl font-bold text-on-surface tracking-tighter font-headline hover:text-accent transition-colors group whitespace-nowrap">
					<span class="material-symbols-outlined text-accent opacity-0 group-hover:opacity-100 transition-opacity hidden md:inline">home</span>
					AI Unpacked
				</a>
			</div>
			<div class="flex items-center gap-4 md:gap-6">
				<!-- Language Switcher -->
				<div class="relative">
					<button id="lang-toggle" class="p-2 rounded-full hover:bg-surface-container transition-colors flex items-center gap-1 text-sm font-semibold text-on-surface" aria-label="Language Selector">
						<span class="material-symbols-outlined text-base">language</span>
						<span class="lang-label font-bold tracking-widest text-xs uppercase ml-0.5">{isZh ? '繁' : 'EN'}</span>
						<span class="material-symbols-outlined text-sm ml-[-2px]">arrow_drop_down</span>
					</button>
					<div id="lang-dropdown" class="absolute right-0 mt-2 w-36 bg-surface-container rounded-xl shadow-xl hidden transition-all duration-200 z-50 overflow-hidden border border-outline-variant/30 py-1">
						<button data-lang="en" class="lang-option w-full text-left block px-5 py-2.5 text-sm font-medium text-on-surface hover:bg-accent/10 hover:text-accent transition-colors flex items-center justify-between">
							English
							<span class={`material-symbols-outlined text-xs ${!isZh ? 'opacity-100' : 'opacity-0'}`}>check</span>
						</button>
						<button data-lang="zh-hant-hk" class="lang-option w-full text-left block px-5 py-2.5 text-sm font-medium text-on-surface hover:bg-accent/10 hover:text-accent transition-colors flex items-center justify-between">
							繁體中文
							<span class={`material-symbols-outlined text-xs ${isZh ? 'opacity-100' : 'opacity-0'}`}>check</span>
						</button>
					</div>
				</div>

				<button id="theme-toggle" class="p-2 rounded-full hover:bg-surface-container transition-colors" aria-label="Toggle theme">
					<span class="material-symbols-outlined text-on-surface dark:hidden">dark_mode</span>
					<span class="material-symbols-outlined text-on-surface hidden dark:block">light_mode</span>
				</button>
				<a class="hidden md:block font-headline font-semibold text-sm tracking-tight text-on-surface opacity-70 hover:opacity-100 hover:text-accent transition-all" href={langPrefix + "/who-is-this-for"}>{i18n.who}</a>
				<a class="hidden md:block font-headline font-semibold text-sm tracking-tight text-on-surface opacity-70 hover:opacity-100 hover:text-accent transition-all" href={langPrefix + "/about"}>{i18n.about}</a>
			</div>
		</nav>

		<!-- Mobile Drawer Overlay -->
		<div id="mobile-drawer-overlay" class="fixed inset-0 bg-black/50 z-40 hidden opacity-0 transition-opacity duration-300 lg:hidden backdrop-blur-sm"></div>

		<div class="flex pt-16 min-h-screen">
			<!-- SideNavBar (Desktop & Mobile Drawer) -->
			<aside id="sidebar" class="sidebar fixed lg:sticky left-0 top-0 pt-20 lg:pt-8 bg-surface-container-low flex flex-col gap-2 p-4 z-50 h-screen w-72 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out border-r border-outline-variant/20 shadow-2xl lg:shadow-none">
				<div class="flex items-center justify-between lg:hidden mb-6 px-2">
					<h2 class="text-xl font-bold text-on-surface font-headline whitespace-nowrap">{i18n.menu}</h2>
					<button id="menu-close" class="p-2 rounded-md hover:bg-surface-container transition-colors">
						<span class="material-symbols-outlined text-on-surface">close</span>
					</button>
				</div>
				<div class="mb-6 px-2">
					<h2 class="text-lg font-bold text-on-surface font-headline">{i18n.curriculum}</h2>
					<p class="text-xs text-on-surface-variant font-medium uppercase tracking-wider">{i18n.mastery}</p>
				</div>
				<nav class="flex flex-col gap-1 overflow-y-auto max-h-[calc(100vh-160px)]">
					<!-- Slot for dynamic Table of Contents or Sidebar Links -->
					<slot name="sidebar">
						<SidebarTOC activeId={activeId} />
					</slot>
				</nav>
			</aside>

			<!-- Main Content Canvas -->
			<main class="w-full px-6 md:px-12 py-16 lg:py-24 max-w-4xl mx-auto pb-32 lg:pb-16">
				{!hideHeader && (
					<header class="mb-12">
						{chapter && (
							<nav class="flex items-center gap-2 text-primary font-bold text-sm mb-4">
								<a href={langPrefix + "/"} class="hover:underline">{i18n.overview}</a>
								<span class="material-symbols-outlined text-xs">chevron_right</span>
								<span>{chapter}</span>
							</nav>
						)}
						<h1 class="text-3xl md:text-5xl font-extrabold font-headline tracking-tighter text-on-surface mb-6 leading-tight">
							{title}
						</h1>
						{description && (
							<p class="text-lg md:text-xl text-on-surface-variant max-w-2xl font-medium leading-relaxed">
								{description}
							</p>
						)}
					</header>
				)}

				<div class="content-body prose prose-lg dark:prose-invert max-w-none prose-headings:font-headline prose-a:text-accent hover:prose-a:text-accent-dark">
					<slot />
				</div>

				<!-- Navigation Buttons -->
				<nav class="flex justify-between items-center pt-8 mt-20 border-t border-outline-variant/20">
					<slot name="prev-link" />
					<slot name="next-link" />
				</nav>
			</main>
		</div>

		<!-- Sticky Bottom Nav for Mobile -->
		<div class="lg:hidden fixed bottom-0 left-0 w-full bg-surface-container-low border-t border-outline-variant/20 p-4 z-40 flex justify-between items-center shadow-[0_-10px_20px_rgba(0,0,0,0.05)] safe-area-bottom">
			<slot name="mobile-prev-link">
				<div></div>
			</slot>
			<slot name="mobile-next-link">
				<div></div>
			</slot>
		</div>

		<!-- Footer -->
		<footer class="hidden lg:flex w-full py-12 mt-10 bg-background border-t border-outline-variant/10 flex-col items-center justify-center gap-4 text-center">
			<p class="font-label text-xs uppercase tracking-widest text-on-surface opacity-40">© 2026 Long. Made with curiosity.</p>
		</footer>

		<script is:inline>
			// Load main.js and quizzes.js using the base URL from the meta tag
			(function() {
				const BASE = document.querySelector('meta[name="base-url"]').content;
				['js/main.js', 'js/quizzes.js'].forEach(function(src) {
					const s = document.createElement('script');
					s.src = BASE + src;
					document.body.appendChild(s);
				});
			})();
		</script>
		<script is:inline>
			// Theme Toggle Logic
			const handleToggleClick = () => {
				const element = document.documentElement;
				element.classList.toggle("dark");

				const isDark = element.classList.contains("dark");
				localStorage.setItem("theme", isDark ? "dark" : "light");
			};

			document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);

			// Language Switcher Logic
			const BASE = document.querySelector('meta[name="base-url"]').content;
			// BASE ends with '/', e.g. '/llm_tutorial_site/'
			const BASE_NO_SLASH = BASE.slice(0, -1); // '/llm_tutorial_site'

			const stripBase = (p) => {
				const lower = p.toLowerCase();
				const lowerBase = BASE_NO_SLASH.toLowerCase();
				return lower.startsWith(lowerBase) ? p.slice(BASE_NO_SLASH.length) : p;
			};

			const updateLangLabel = () => {
				const stripped = stripBase(window.location.pathname).toLowerCase();
				const label = document.querySelector('.lang-label');
				if (label) {
					label.textContent = stripped.startsWith('/zh-hant-hk') ? '繁' : 'EN';
				}
			};
			updateLangLabel();

			document.getElementById('lang-toggle')?.addEventListener('click', () => {
				document.getElementById('lang-dropdown')?.classList.toggle('hidden');
			});
			document.addEventListener('click', (e) => {
				if (!e.target.closest('#lang-toggle') && !e.target.closest('#lang-dropdown')) {
					document.getElementById('lang-dropdown')?.classList.add('hidden');
				}
			});

			document.querySelectorAll('.lang-option').forEach(btn => {
				btn.addEventListener('click', (e) => {
					const targetLang = e.currentTarget.getAttribute('data-lang').toLowerCase();
					const currentPath = window.location.pathname;
					const strippedPath = stripBase(currentPath);
					const lowerStripped = strippedPath.toLowerCase();

					// Handle root and localized roots
					if (lowerStripped === '/' || lowerStripped === '/en' || lowerStripped === '/en/' || lowerStripped === '/zh-hant-hk' || lowerStripped === '/zh-hant-hk/') {
						window.location.href = targetLang === 'zh-hant-hk' ? BASE + 'zh-hant-hk/' : BASE + 'en/';
						return;
					}

					let newStripped = strippedPath;
					if (targetLang === 'zh-hant-hk') {
						if (lowerStripped.startsWith('/en/')) {
							newStripped = strippedPath.replace(/^\/en\//i, '/zh-hant-hk/');
						} else if (!lowerStripped.startsWith('/zh-hant-hk/')) {
							newStripped = '/zh-hant-hk' + strippedPath;
						}
					} else {
						if (lowerStripped.startsWith('/zh-hant-hk/')) {
							newStripped = strippedPath.replace(/^\/zh-hant-hk\//i, '/en/');
						} else if (!lowerStripped.startsWith('/en/')) {
							newStripped = '/en' + strippedPath;
						}
					}

					window.location.pathname = BASE_NO_SLASH + newStripped;
				});
			});

			// Mobile Drawer Logic
			const sidebar = document.getElementById('sidebar');
			const overlay = document.getElementById('mobile-drawer-overlay');
			const menuToggle = document.getElementById('menu-toggle');
			const menuClose = document.getElementById('menu-close');

			const openMenu = () => {
				sidebar?.classList.remove('-translate-x-full');
				overlay?.classList.remove('hidden');
				// Small delay to allow display block to apply before animating opacity
				setTimeout(() => {
					overlay?.classList.remove('opacity-0');
				}, 10);
				document.body.style.overflow = 'hidden'; // Prevent background scrolling
			};

			const closeMenu = () => {
				sidebar?.classList.add('-translate-x-full');
				overlay?.classList.add('opacity-0');
				setTimeout(() => {
					overlay?.classList.add('hidden');
				}, 300); // match transition duration
				document.body.style.overflow = '';
			};

			menuToggle?.addEventListener('click', openMenu);
			menuClose?.addEventListener('click', closeMenu);
			overlay?.addEventListener('click', closeMenu);

			// Dynamically load interactive scripts based on data-interactive attribute
			document.addEventListener('DOMContentLoaded', () => {
				const interactives = document.querySelectorAll('[data-interactive]');
				if (interactives.length > 0) {
					// Load core.js first
					const coreScript = document.createElement('script');
					coreScript.src = BASE + 'js/interactives/core.js';
					document.body.appendChild(coreScript);

					coreScript.onload = () => {
						// Load individual interactive scripts
						interactives.forEach(el => {
							const id = el.getAttribute('data-interactive');
							if (id) {
								const script = document.createElement('script');
								script.src = BASE + `js/interactives/${id}.js`;
								document.body.appendChild(script);
							}
						});
					};
				}
			});
		</script>
	</body>
</html>
