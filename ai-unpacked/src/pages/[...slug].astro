---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarTOC from '../components/SidebarTOC.astro';
import { getNavPages } from '../data/navigation';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Determine current language
const currentLang = entry.id.split('/')[0];
const pages = await getNavPages(currentLang);

const activeId = entry.data.pageId || entry.id;

// Previous and Next links
const currentIndex = pages.findIndex(p => p.id === activeId);
const prevPage = currentIndex > 0 ? pages[currentIndex - 1] : null;
const nextPage = currentIndex < pages.length - 1 ? pages[currentIndex + 1] : null;

const langPrefix = `/${currentLang}`;
const isZh = currentLang === 'zh-hant-hk';
const labels = {
    back: isZh ? "返回概覽" : "Back to Overview",
    next: isZh ? "下一步" : "Next",
    finish: isZh ? "完成" : "Finish"
};

---

<BaseLayout 
  title={entry.data.title} 
  description={entry.data.description} 
  chapter={entry.data.chapter}
  activeId={activeId}
>
  <Fragment slot="sidebar">
      <SidebarTOC activeId={activeId} lang={currentLang} />
  </Fragment>

  <Fragment slot="prev-link">
      {prevPage && (
          <a href={prevPage.file} class="flex items-center gap-2 text-primary font-bold hover:gap-3 transition-all no-underline">
              <span class="material-symbols-outlined">arrow_back</span>
              {prevPage.title}
          </a>
      )}
  </Fragment>

  <Fragment slot="next-link">
      {nextPage ? (
          <a href={nextPage.file} class="flex items-center gap-2 text-primary font-bold hover:gap-3 transition-all no-underline text-right">
              {nextPage.title}
              <span class="material-symbols-outlined">arrow_forward</span>
          </a>
      ) : (
          <a href={langPrefix + "/"} class="flex items-center gap-2 text-primary font-bold hover:gap-3 transition-all no-underline text-right">
              {labels.back}
              <span class="material-symbols-outlined">home</span>
          </a>
      )}
  </Fragment>

  <!-- Mobile Sticky Nav Links -->
  <Fragment slot="mobile-prev-link">
      {prevPage && (
          <a href={prevPage.file} class="p-2 bg-surface-container rounded-full text-on-surface flex items-center justify-center">
              <span class="material-symbols-outlined text-sm">arrow_back</span>
          </a>
      )}
  </Fragment>

  <Fragment slot="mobile-next-link">
      {nextPage ? (
          <a href={nextPage.file} class="bg-primary text-on-primary font-bold py-3 px-6 rounded-full text-sm shadow-md flex items-center gap-2">
              {labels.next}
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
      ) : (
          <a href={langPrefix + "/"} class="bg-primary text-on-primary font-bold py-3 px-6 rounded-full text-sm shadow-md flex items-center gap-2">
              {labels.finish}
              <span class="material-symbols-outlined text-sm">flag</span>
          </a>
      )}
  </Fragment>

  <Content />
</BaseLayout>
