---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="About & Contact" description="Hi, I'm Long — 10-year AI & software veteran, based in Hong Kong, serving clients globally." hideHeader={true}>
  
  <header class="mb-12 mt-8 fade-in">
      <h1 class="text-5xl md:text-6xl font-headline font-extrabold text-on-surface tracking-tight mb-6">
          About & Contact
      </h1>
      <p class="text-xl text-on-surface-variant leading-relaxed">
          Hi, I'm <strong>Long</strong> — 10-year AI & software veteran, based in Hong Kong, serving clients globally.
      </p>
  </header>

  <div class="mb-12 mt-8">
      <p class="text-on-surface-variant leading-relaxed text-lg">
          Friends and colleagues kept asking me the same question: <em>"Why isn't AI doing what I asked?"</em> After 10 years building products across data analytics, automotive software, computer vision, and medical AI, I realized the gap wasn't intelligence — it was intuition. So I built this course to give people the mental models they need to actually work with AI, not just use it.
      </p>
  </div>

  <!-- Equation Banner Tagline -->
  <div class="flex justify-center mb-16 mt-8">
      <div class="equation-banner px-10 py-6 rounded-full inline-flex items-center gap-4 rotate-[-1deg] bg-gradient-to-br from-accent to-primary text-white shadow-lg">
          <span class="text-xl md:text-2xl font-extrabold font-headline text-center text-white">I help you with anything and everything AI</span>
      </div>
  </div>

  <!-- What I Do -->
  <div class="space-y-6 mb-16">
      <h2 class="text-2xl font-headline font-bold text-on-surface mb-6">What I do</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm border border-outline-variant/10">
              <h3 class="font-headline font-bold text-on-surface mb-2 flex items-center gap-2">
                  <span class="text-xl">🧭</span> AI Strategy & Consulting
              </h3>
              <p class="text-on-surface-variant text-sm leading-relaxed mt-2">Figure out what your company should — and shouldn't — do with AI.</p>
          </div>

          <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm border border-outline-variant/10">
              <h3 class="font-headline font-bold text-on-surface mb-2 flex items-center gap-2">
                  <span class="text-xl">🛠️</span> Implementation & Development
              </h3>
              <p class="text-on-surface-variant text-sm leading-relaxed mt-2">Available to build it, not just advise on it. From prototype to production.</p>
          </div>

          <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm border border-outline-variant/10">
              <h3 class="font-headline font-bold text-on-surface mb-2 flex items-center gap-2">
                  <span class="text-xl">🎓</span> Corporate Training
              </h3>
              <p class="text-on-surface-variant text-sm leading-relaxed mt-2">From executive briefings to hands-on team workshops, tailored to your level.</p>
          </div>

          <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm border border-outline-variant/10">
              <h3 class="font-headline font-bold text-on-surface mb-2 flex items-center gap-2">
                  <span class="text-xl">⚙️</span> Process Automation
              </h3>
              <p class="text-on-surface-variant text-sm leading-relaxed mt-2">Identify what to automate, architect the solution, and ship it.</p>
          </div>

          <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm border border-outline-variant/10 md:col-span-2">
              <h3 class="font-headline font-bold text-on-surface mb-2 flex items-center gap-2">
                  <span class="text-xl">🔍</span> Technical Due Diligence
              </h3>
              <p class="text-on-surface-variant text-sm leading-relaxed mt-2">Evaluate AI vendors, review architectures, and assess feasibility — before you commit.</p>
          </div>
      </div>
  </div>

  <!-- Contact -->
  <section class="bg-secondary-container rounded-xl p-8 flex gap-6 items-start mt-12">
      <span class="text-4xl leading-none hidden md:block">📧</span>
      <div class="space-y-4">
          <h4 class="font-bold text-on-secondary-container uppercase tracking-widest text-xs">Get in Touch</h4>
          <p class="text-on-secondary-container font-medium text-lg leading-relaxed">
              Whether you're a 5-person startup or a 500-person enterprise — the same fundamentals apply, just at different scales. Let's talk.
          </p>
          <div class="space-y-2 text-on-secondary-container mt-4">
              <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-lg">person</span>
                  <span><strong>Long</strong> — 10 years in AI, data & software · UC Berkeley Applied Math</span>
              </div>
              <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-lg">location_on</span>
                  <span>Hong Kong · Serving clients globally</span>
              </div>
          </div>
          <div class="flex flex-wrap gap-4 mt-6">
              <a href="mailto:longhui@berkeley.edu" class="inline-flex items-center gap-2 text-primary font-bold hover:underline text-lg">
                  <span class="material-symbols-outlined text-xl">mail</span>
                  longhui@berkeley.edu
              </a>
              <a href="https://www.linkedin.com/in/longhui1996" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-primary font-bold hover:underline text-lg">
                  <span class="material-symbols-outlined text-xl">link</span>
                  LinkedIn
              </a>
          </div>
      </div>
  </section>

  <!-- How I Built This link -->
  <div class="mt-12 mb-16">
      <a href="/en/special-how-i-built-this-01" class="group bg-surface-container-low rounded-xl p-6 flex items-center gap-4 hover:bg-surface-container hover:shadow-md transition-all no-underline">
          <span class="text-3xl hidden md:block">🏗️</span>
          <div>
              <p class="font-headline font-bold text-on-surface group-hover:text-accent transition-colors m-0">Want to see how I built this site?</p>
              <p class="text-on-surface-variant text-sm mt-1 m-0">Read how I built this entire course — from curriculum design to AI-assisted development.</p>
          </div>
          <span class="material-symbols-outlined text-primary ml-auto group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </a>
  </div>
</BaseLayout>
