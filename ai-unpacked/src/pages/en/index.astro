---
import BaseLayout from '../../layouts/BaseLayout.astro';
import courseData from '../../data/course-structure.json';
---

<BaseLayout title="Course Overview" description="An interactive journey through the concepts behind Large Language Models." hideHeader={true}>
  <header class="mb-16 fade-in">
      <h1 class="text-5xl md:text-7xl font-headline font-extrabold text-on-surface tracking-tight mb-4">
          Course Overview
      </h1>
      <p class="text-xl text-on-surface-variant max-w-2xl leading-relaxed">
          An interactive journey through the concepts behind Large Language Models. No math, no code — just hands-on interactives and clear analogies to build real intuition. From tokenization to boardroom strategy.
      </p>
  </header>

  <!-- Chapter Groups -->
  <div class="space-y-20">
      {courseData.groups.map(group => {
          const groupTitle = group.name.includes(':') ? group.name.split(':')[1].trim() : group.name;
          
          return (
              <section>
                  <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-4 mb-8">
                      <h2 class="text-3xl font-headline font-bold text-primary uppercase">{groupTitle}</h2>
                      <span class="hidden md:block h-px flex-1 bg-outline-variant opacity-15"></span>
                      <span class="text-sm font-label uppercase tracking-widest text-on-surface-variant opacity-60">{group.subtitle}</span>
                  </div>
                  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                      {group.chapters.map(chapter => {
                          const isComingSoon = chapter.status !== 'active';
                          const chapterLabel = chapter.special ? 'SPECIAL' : `Chapter ${chapter.id}`;
                          
                          // chapter.firstPage is like "chapter-01-01.html"
                          const slug = chapter.firstPage.replace('.html', '');
                          const BASE = (import.meta.env.BASE_URL + '/').replace(/\/+$/, '/');
                          const linkHref = isComingSoon ? null : `${BASE}en/${slug}`;
                          const opacityClass = isComingSoon ? 'opacity-60' : '';
                          
                          return (
                              <a href={linkHref} class={`group cursor-pointer bg-surface-container-low p-8 rounded-xl transition-all hover:bg-surface-container hover:shadow-[0_20px_40px_rgba(146,74,49,0.06)] relative overflow-hidden block no-underline ${opacityClass}`}>
                                  <span class={`absolute top-4 right-6 text-4xl opacity-20 ${!isComingSoon ? 'group-hover:opacity-100 transition-opacity' : ''}`}>{chapter.icon}</span>
                                  <p class="text-xs font-label font-bold text-primary mb-2 uppercase tracking-widest m-0">{chapterLabel}</p>
                                  <h3 class="text-xl font-headline font-bold text-on-surface mb-4 mt-0">{chapter.title}</h3>
                                  <p class="text-sm text-on-surface-variant leading-relaxed mb-6 m-0">{chapter.description}</p>
                                  <div class="flex items-center gap-2 text-primary font-bold text-sm mt-auto">
                                      {isComingSoon ? (
                                          <span>Coming Soon</span>
                                      ) : (
                                          <>
                                              <span>Start Learning</span>
                                              <span class="material-symbols-outlined text-sm">arrow_forward</span>
                                          </>
                                      )}
                                  </div>
                              </a>
                          );
                      })}
                  </div>
              </section>
          );
      })}
  </div>

  <p class="text-center text-on-surface-variant text-sm mt-16 pb-8">More chapters coming soon. This course is actively being updated.</p>
</BaseLayout>
